# =============================================================
#  Variables de entorno — Stack Laravel + Docker
#  IMPORTANTE: Copia este archivo como ".env" y ajusta los valores
#  NUNCA subas el .env real a Git (está en .gitignore)
# =============================================================

# ------- Laravel -------
APP_NAME="Mi Proyecto Laravel"
APP_ENV=local
APP_KEY=                          # Se genera con: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8080     # Puerto de Nginx en docker-compose

# ------- Base de datos PostgreSQL -------
# ¡¡ DB_HOST DEBE ser "postgres" (nombre del servicio) NO "localhost" !!
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel_db
DB_USERNAME=laravel_user
DB_PASSWORD=secret

# ------- Redis -------
REDIS_HOST=redis                  # Nombre del servicio, NO localhost
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------- Cache, Sesiones y Colas -------
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ------- Mail (opcional, para desarrollo usa log o mailtrap) -------
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------- pgAdmin -------
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin123
